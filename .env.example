# Supabase — get these from your project's API settings.
# Public (safe to expose to the browser):
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-OR-PUBLISHABLE-KEY

# Public base URL of the site (used for share links, QR codes, sitemap).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only (NEVER expose to the browser). Used by admin/server actions
# that must bypass RLS (e.g. counting facets, incrementing downloads).
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Storage bucket names (created in Supabase Storage).
NEXT_PUBLIC_SUPABASE_PDF_BUCKET=curricula
NEXT_PUBLIC_SUPABASE_COVER_BUCKET=covers
